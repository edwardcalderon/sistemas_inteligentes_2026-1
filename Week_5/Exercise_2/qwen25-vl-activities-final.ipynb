   "source": [
    "# Video Understanding Analysis with Qwen2.5-VL\n",
    "\n",
    "## Objective:\n",
    "Complete video analysis using Qwen2.5-VL with real videos.\n",
    "\n",
    "### Activities:\n",
    "1. Download real videos\n",
    "2. Activity 1: General description\n",
    "3. Activity 2: FPS vs Quality trade-off\n",
    "4. Activity 3: Temporal localization\n",
    "5. Academic report generation\n",
    "\n",
    "---"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Install dependencies\n",
    "!pip install -q transformers>=4.49.0 accelerate qwen-vl-utils bitsandbytes decord requests\n",
    "!pip install -q opencv-python matplotlib seaborn"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import os\n",
    "import cv2\n",
    "from pathlib import Path\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "import time\n",
    "import json\n",
    "from datetime import datetime\n",
    "\n",
    "# Configuration\n",
    "VIDEO_DIR = Path(\"./videos\")\n",
    "VIDEO_DIR.mkdir(exist_ok=True)\n",
    "\n",
    "print(\"Configuration completed\")\n",
    "print(f\"Video directory: {VIDEO_DIR.absolute()}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Use real videos\n",
    "downloaded_videos = {\n",
    "    \"cooking\": \"videos/cooking.mp4\",\n",
    "    \"sports\": \"videos/sport.mp4\"\n",
    "}\n",
    "\n",
    "print(f\"Videos configured: {len(downloaded_videos)}\")\n",
    "for name, path in downloaded_videos.items():\n",
    "    print(f\"  {name}: {path}\")\n",
    "    \n",
    "# Verify video information\n",
    "for name, path in downloaded_videos.items():\n",
    "    if os.path.exists(path):\n",
    "        cap = cv2.VideoCapture(path)\n",
    "        fps = cap.get(cv2.CAP_PROP_FPS)\n",
    "        frame_count = int(cap.get(cv2.CAP_PROP_FRAME_COUNT))\n",
    "        duration = frame_count / fps if fps > 0 else 0\n",
    "        width = int(cap.get(cv2.CAP_PROP_FRAME_WIDTH))\n",
    "        height = int(cap.get(cv2.CAP_PROP_FRAME_HEIGHT))\n",
    "        cap.release()\n",
    "        \n",
    "        print(f\"\\n{name.upper()}:\")\n",
    "        print(f\"  Resolution: {width}x{height}\")\n",
    "        print(f\"  FPS: {fps:.2f}\")\n",
    "        print(f\"  Duration: {duration:.1f}s\")\n",
    "        print(f\"  Frames: {frame_count}\")\n",
    "    else:\n",
    "        print(f\"Video not found: {path}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Model Loading - CPU Version for GTX 1060"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Load model - CPU version for GTX 1060 compatibility\n",
    "import torch\n",
    "import time\n",
    "\n",
    "print(\"Starting model load for GTX 1060...\")\n",
    "\n",
    "# Force CPU due to GTX 1060 incompatibility\n",
    "device = \"cpu\"\n",
    "print(f\"Device: {device} (forced for compatibility)\")\n",
    "print(\"GTX 1060 incompatible - using CPU\")\n",
    "\n",
    "# Verify videos\n",
    "missing_videos = []\n",
    "for name, path in downloaded_videos.items():\n",
    "    if not os.path.exists(path):\n",
    "        missing_videos.append(f\"{name}: {path}\")\n",
    "\n",
    "if missing_videos:\n",
    "    print(\"Videos not found:\")\n",
    "    for missing in missing_videos:\n",
    "        print(f\"  {missing}\")\n",
    "    raise FileNotFoundError(\"Videos not found\")\n",
    "\n",
    "print(\"All videos found\")\n",
    "\n",
    "# Import and load on CPU\n",
    "try:\n",
    "    from transformers import AutoProcessor, Qwen2_5_VLForConditionalGeneration\n",
    "    from qwen_vl_utils import process_vision_info\n",
    "    from IPython.display import Video, display\n",
    "    \n",
    "    model_id = \"Qwen/Qwen2.5-VL-3B-Instruct\"\n",
    "    start_time = time.time()\n",
    "    \n",
    "    print(\"Loading on CPU...\")\n",
    "    processor = AutoProcessor.from_pretrained(model_id, trust_remote_code=True)\n",
    "    \n",
    "    model = Qwen2_5_VLForConditionalGeneration.from_pretrained(\n",
    "        model_id,\n",
    "        torch_dtype=torch.float32,\n",
    "        device_map=\"cpu\",\n",
    "        low_cpu_mem_usage=True\n",
    "    )\n",
    "    \n",
    "    load_time = time.time() - start_time\n",
    "    print(f\"Model loaded on CPU in {load_time:.1f}s\")\n",
    "    \n",
    "except Exception as e:\n",
    "    print(f\"Error: {str(e)}\")\n",
    "    raise e"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Video Analysis Functions"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def ask_video_cpu(video_path, question, fps=0.5, max_new_tokens=150):\n",
    "    \"\"\"CPU optimized version\"\"\"\n",
    "    try:\n",
    "        messages = [{\n",
    "            \"role\": \"user\",\n",
    "            \"content\": [\n",
    "                {\n",
    "                    \"type\": \"video\",\n",
    "                    \"video\": video_path,\n",
    "                    \"fps\": fps,\n",
    "                    \"max_pixels\": 180*210\n",
    "                },\n",
    "                {\"type\": \"text\", \"text\": question}\n",
    "            ]\n",
    "        }]\n",
    "\n",
    "        text_prompt = processor.apply_chat_template(\n",
    "            messages, tokenize=False, add_generation_prompt=True\n",
    "        )\n",
    "\n",
    "        _, video_inputs = process_vision_info(messages)\n",
    "        inputs = processor(\n",
    "            text=[text_prompt],\n",
    "            videos=video_inputs,\n",
    "            return_tensors=\"pt\"\n",
    "        )\n",
    "\n",
    "        with torch.no_grad():\n",
    "            output_ids = model.generate(\n",
    "                **inputs,\n",
    "                max_new_tokens=max_new_tokens,\n",
    "                do_sample=False\n",
    "            )\n",
    "\n",
    "        generated_ids = output_ids[:, inputs[\"input_ids\"].shape[1]:]\n",
    "        return processor.decode(generated_ids[0], skip_special_tokens=True)\n",
    "        \n",
    "    except Exception as e:\n",
    "        print(f\"CPU Error: {str(e)}\")\n",
    "        return f\"Error processing video: {str(e)}\""
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def video_qa_session_cpu(video_path, questions, fps=0.5, max_new_tokens=150):\n",
    "    \"\"\"CPU optimized version\"\"\"\n",
    "    try:\n",
    "        display(Video(video_path, width=400))\n",
    "        print(\"=\" * 60)\n",
    "        print(f\"Video: {video_path}\")\n",
    "        print(f\"fps={fps} (CPU optimized)\")\n",
    "        print(\"=\" * 60)\n",
    "\n",
    "        results = []\n",
    "        for i, question in enumerate(questions, 1):\n",
    "            print(f\"\\nQuestion {i}: {question}\")\n",
    "            start_time = time.time()\n",
    "            answer = ask_video_cpu(video_path, question, fps=fps, max_new_tokens=max_new_tokens)\n",
    "            elapsed = time.time() - start_time\n",
    "            print(f\"Answer {i}: {answer}\")\n",
    "            print(f\"CPU Time: {elapsed:.2f}s\")\n",
    "            print(\"-\" * 60)\n",
    "            \n",
    "            results.append({\n",
    "                \"question\": question,\n",
    "                \"answer\": answer,\n",
    "                \"time\": elapsed,\n",
    "                \"fps\": fps\n",
    "            })\n",
    "        \n",
    "        return results\n",
    "    except Exception as e:\n",
    "        print(f\"Session Error: {e}\")\n",
    "        return []"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Activity 1: General Video Description"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Activity 1: CPU optimized version\n",
    "activity1_results = {}\n",
    "\n",
    "general_question = \"Describe what happens in this video. Focus on main actions and setting.\"\n",
    "\n",
    "for video_name, video_path in downloaded_videos.items():\n",
    "    print(f\"\\nCPU ANALYSIS: {video_name.upper()}\")\n",
    "    print(\"=\" * 60)\n",
    "    \n",
    "    if not os.path.exists(video_path):\n",
    "        print(f\"Video not found: {video_path}\")\n",
    "        continue\n",
    "    \n",
    "    try:\n",
    "        display(Video(video_path, width=400))\n",
    "        \n",
    "        print(f\"\\nAnalysis (fps=0.5):\")\n",
    "        start_time = time.time()\n",
    "        description = ask_video_cpu(\n",
    "            video_path, \n",
    "            general_question,\n",
    "            fps=0.5,\n",
    "            max_new_tokens=200\n",
    "        )\n",
    "        elapsed = time.time() - start_time\n",
    "        \n",
    "        print(f\"Description:\\n{description}\")\n",
    "        print(f\"CPU Time: {elapsed:.2f}s\")\n",
    "        print(\"-\" * 60)\n",
    "        \n",
    "        activity1_results[video_name] = {\n",
    "            \"description\": description,\n",
    "            \"time\": elapsed,\n",
    "            \"fps\": 0.5\n",
    "        }\n",
    "    except Exception as e:\n",
    "        print(f\"Error {video_name}: {e}\")\n",
    "        continue\n",
    "\n",
    "print(\"\\nActivity 1 completed\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Activity 2: FPS vs Quality Trade-off"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Activity 2: CPU optimized version\n",
    "activity2_results = {}\n",
    "\n",
    "test_video = downloaded_videos.get(\"cooking\") or downloaded_videos.get(\"sports\")\n",
    "\n",
    "chronological_question = \"Describe main steps in this video in order.\"\n",
    "\n",
    "if test_video and os.path.exists(test_video):\n",
    "    print(f\"FPS ANALYSIS: {'COOKING' if 'cooking' in test_video else 'SPORTS'}\")\n",
    "    display(Video(test_video, width=400))\n",
    "    \n",
    "    fps_values = [0.5, 1.0]\n",
    "    \n",
    "    for fps_val in fps_values:\n",
    "        print(f\"\\nCPU fps={fps_val}:\")\n",
    "        \n",
    "        try:\n",
    "            start_time = time.time()\n",
    "            answer = ask_video_cpu(\n",
    "                test_video, \n",
    "                chronological_question, \n",
    "                fps=fps_val, \n",
    "                max_new_tokens=150\n",
    "            )\n",
    "            elapsed = time.time() - start_time\n",
    "            \n",
    "            print(f\"Answer:\\n{answer}\")\n",
    "            print(f\"CPU Time: {elapsed:.1f}s\")\n",
    "            print(\"-\" * 40)\n",
    "            \n",
    "            activity2_results[f\"fps_{fps_val}\"] = {\n",
    "                \"answer\": answer,\n",
    "                \"time\": elapsed,\n",
    "                \"fps\": fps_val\n",
    "            }\n",
    "        except Exception as e:\n",
    "            print(f\"Error fps={fps_val}: {e}\")\n",
    "else:\n",
    "    print(\"No videos available for analysis\")\n",
    "\n",
    "print(\"\\nActivity 2 completed\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Activity 3: Temporal Event Localization"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Activity 3: CPU optimized version\n",
    "activity3_results = {}\n",
    "\n",
    "temporal_questions = {\n",
    "    \"cooking\": [\n",
    "        \"When does main cooking action start?\",\n",
    "        \"What changes happen in middle of video?\",\n",
    "        \"How does video end?\"\n",
    "    ],\n",
    "    \"sports\": [\n",
    "        \"When does main action begin?\",\n",
    "        \"What happens during key moment?\",\n",
    "        \"How does it conclude?\"\n",
    "    ]\n",
    "}\n",
    "\n",
    "for video_name, video_path in downloaded_videos.items():\n",
    "    print(f\"\\nTEMPORAL LOCALIZATION: {video_name.upper()}\")\n",
    "    print(\"=\" * 60)\n",
    "    \n",
    "    if not os.path.exists(video_path):\n",
    "        print(f\"Video not found: {video_path}\")\n",
    "        continue\n",
    "    \n",
    "    try:\n",
    "        display(Video(video_path, width=400))\n",
    "        \n",
    "        questions = temporal_questions.get(video_name, [\n",
    "            \"What happens at beginning?\",\n",
    "            \"What changes occur?\",\n",
    "            \"How does it end?\"\n",
    "        ])\n",
    "        \n",
    "        results = video_qa_session_cpu(video_path, questions, fps=0.5, max_new_tokens=100)\n",
    "        activity3_results[video_name] = results\n",
    "        \n",
    "    except Exception as e:\n",
    "        print(f\"Error {video_name}: {e}\")\n",
    "        activity3_results[video_name] = []\n",
    "\n",
    "print(\"\\nActivity 3 completed\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Results Analysis"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Consolidated analysis\n",
    "print(\"CONSOLIDATED RESULTS ANALYSIS\")\n",
    "print(\"=\" * 80)\n",
    "\n",
    "# Activity 1 analysis\n",
    "print(\"\\nACTIVITY 1 - General Description:\")\n",
    "for video_name, results in activity1_results.items():\n",
    "    print(f\"\\nVideo: {video_name}\")\n",
    "    print(f\"  Time: {results['time']:.2f}s\")\n",
    "    print(f\"  Quality: {'High' if len(results['description']) > 100 else 'Medium'}\")\n",
    "\n",
    "# Activity 2 analysis\n",
    "print(\"\\nACTIVITY 2 - FPS vs Quality:\")\n",
    "fps_times = {fps: data['time'] for fps, data in activity2_results.items()}\n",
    "for fps, time_taken in fps_times.items():\n",
    "    fps_val = fps.split('_')[1]\n",
    "    print(f\"  {fps_val}: {time_taken:.2f}s\")\n",
    "\n",
    "# Activity 3 analysis\n",
    "print(\"\\nACTIVITY 3 - Temporal Localization:\")\n",
    "for video_name, results in activity3_results.items():\n",
    "    if results:\n",
    "        avg_time = sum(r['time'] for r in results) / len(results)\n",
    "        print(f\"  {video_name}: {avg_time:.2f}s average per question\")\n",
    "        print(f\"  Questions answered: {len(results)}\")\n",
    "\n",
    "# Save results for report\n",
    "all_results = {\n",
    "    \"activity1\": activity1_results,\n",
    "    \"activity2\": activity2_results,\n",
    "    \"activity3\": activity3_results,\n",
    "    \"metadata\": {\n",
    "        \"timestamp\": datetime.now().isoformat(),\n",
    "        \"videos_used\": list(downloaded_videos.keys()),\n",
    "        \"total_videos\": len(downloaded_videos)\n",
    "    }\n",
    "}\n",
    "\n",
    "# Save results to JSON\n",
    "with open(\"video_analysis_results.json\", \"w\") as f:\n",
    "    json.dump(all_results, f, indent=2)\n",
    "\n",
    "print(\"\\nResults saved to 'video_analysis_results.json'\")\n",
    "print(\"Ready for academic report generation\")"
   ]
  },
